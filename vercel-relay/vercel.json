{
  "rewrites": [
    {
      "source": "/api/jobs",
      "destination": "/api/relay?route=jobs"
    },
    {
      "source": "/api/next",
      "destination": "/api/relay?route=next"
    },
    {
      "source": "/api/complete",
      "destination": "/api/relay?route=complete"
    },
    {
      "source": "/api/ping",
      "destination": "/api/relay?route=ping"
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  }
}
